<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvSuccess"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Luar Biasa!"
        android:textSize="36sp"
        android:fontFamily="sans-serif-black"
        android:textColor="#FFC800"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/tvSecured"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSecured"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data berhasil diterima dengan baik!"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#AFB6C1"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/terminalBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/terminalBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#F7F7F7"
        app:strokeColor="#E5E5E5"
        app:strokeWidth="2dp"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvHasilPesan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Memuat pesan rahasia..."
            android:textSize="18sp"
            android:textColor="#4B4B4B"
            android:minHeight="150dp"
            android:padding="24dp"
            android:lineSpacingExtra="6dp"
            android:fontFamily="sans-serif-medium"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTutup"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="LANJUTKAN"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        app:cornerRadius="16dp"
        app:backgroundTint="#1CB0F6"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>