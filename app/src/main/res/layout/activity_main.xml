<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kalkulator Bangun"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tv_segitiga_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Luas Segitiga"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <EditText
        android:id="@+id/et_alas_segitiga"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Alas"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/tv_segitiga_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/et_tinggi_segitiga"
        android:layout_marginEnd="8dp"/>

    <EditText
        android:id="@+id/et_tinggi_segitiga"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Masukkan Tinggi"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/tv_segitiga_label"
        app:layout_constraintStart_toEndOf="@id/et_alas_segitiga"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"/>

    <Button
        android:id="@+id/btn_hitung_segitiga"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Luas Segitiga"
        android:backgroundTint="#FF5722"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/et_alas_segitiga"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_kubus_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Volume Kubus"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btn_hitung_segitiga"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <EditText
        android:id="@+id/et_sisi_kubus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan Panjang Sisi"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/tv_kubus_label"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btn_hitung_kubus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Volume Kubus"
        app:layout_constraintTop_toBottomOf="@id/et_sisi_kubus"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_hasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hasil akan tampil di sini"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FF0000"
        android:background="#E0E0E0"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btn_hitung_kubus"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>