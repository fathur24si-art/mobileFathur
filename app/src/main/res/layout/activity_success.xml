<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"> <ImageView
    android:id="@+id/ivSuccessIcon"
    android:layout_width="140dp"
    android:layout_height="140dp"
    android:layout_marginBottom="24dp"
    android:src="@android:drawable/btn_star_big_on"
    app:layout_constraintBottom_toTopOf="@id/tvTitle"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_chainStyle="packed"
    app:tint="#FFD700" /> <TextView
    android:id="@+id/tvTitle"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:letterSpacing="0.05"
    android:text="VERIFIKASI SUKSES!"
    android:textColor="#FFFFFF"
    android:textSize="28sp"
    android:textStyle="bold"
    app:layout_constraintBottom_toTopOf="@id/tvSubtext"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/ivSuccessIcon" />

    <TextView
        android:id="@+id/tvSubtext"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:lineSpacingExtra="6dp"
        android:text="Kode rahasia telah dikirim ke nomor Anda."
        android:textAlignment="center"
        android:textColor="#94A3B8"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/btnSelesai"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelesai"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginHorizontal="32dp"
        android:text="LANJUTKAN"
        android:textColor="#0F172A"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#22D3EE"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtext" />

</androidx.constraintlayout.widget.ConstraintLayout>